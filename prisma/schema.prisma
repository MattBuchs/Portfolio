generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

model License {
  id              String    @id @default(cuid())
  email           String
  licenseKey      String    @unique // Clé chiffrée
  licenseSecret   String    // Secret chiffré
  plan            Plan      @default(FREE)
  maxUsages       Int       // Nombre maximum d'utilisations
  remainingUsages Int       // Nombre d'utilisations restantes
  sessionId       String    @unique // ID de session Stripe
  machineIds      String[]  // Liste des IDs de machines
  customerName    String?
  company         String?
  price           Float?    // Prix payé (après réduction)
  originalPrice   Float?    // Prix original avant réduction
  promoCode       String?   // Code promo utilisé
  discount        Float?    // Montant de la réduction appliquée
  viewCount       Int       @default(0) // Nombre de fois que la clé a été consultée
  viewableUntil   DateTime? // Date limite pour consulter la clé via l'URL
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([email])
  @@index([sessionId])
  @@index([licenseKey])
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCode {
  id              String       @id @default(cuid())
  code            String       @unique
  discountType    DiscountType
  discountValue   Float        // Pourcentage (ex: 20 pour 20%) ou montant fixe (ex: 10 pour 10€)
  maxUses         Int?         // Nombre maximum d'utilisations (null = illimité)
  usedCount       Int          @default(0)
  validFrom       DateTime     @default(now())
  validUntil      DateTime?    // Date d'expiration (null = pas d'expiration)
  isActive        Boolean      @default(true)
  applicablePlans Plan[]       // Plans auxquels ce code s'applique (vide = tous)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([code])
}

model PlanPricing {
  id              String   @id @default(cuid())
  plan            Plan     @unique
  basePrice       Float    // Prix de base
  currentPrice    Float    // Prix actuel
  isOnSale        Boolean  @default(false)
  saleEndDate     DateTime? // Date de fin de la promotion
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AppVersion {
  id            String   @id @default(cuid())
  version       String   @unique // ex: "1.0.0"
  fileName      String   // ex: "GameMasterOS_Setup.exe"
  fileSize      BigInt   // Taille en bytes
  downloadUrl   String?  // URL externe (GitHub Releases, etc.) - optionnel pour migration
  releaseDate   DateTime @default(now())
  releaseNotes  String   // Notes de version en Markdown
  isLatest      Boolean  @default(false) // Une seule version peut être latest
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isLatest])
  @@index([releaseDate])
}

enum FoodTruckRole {
  OWNER
  MANAGER
  STAFF
}

model FoodTruckUser {
  id           String                @id @default(cuid())
  email        String                @unique
  passwordHash String
  name         String
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  memberships  FoodTruckMembership[]
  sessions     FoodTruckSession[]
  invitesSent  FoodTruckInvite[]     @relation("FoodTruckInvitedBy")
}

model FoodTruckWorkspace {
  id             String                    @id @default(cuid())
  name           String
  slug           String                    @unique
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  memberships    FoodTruckMembership[]
  invites        FoodTruckInvite[]
  products       FoodTruckProduct[]        @relation("FoodTruckProducts")
  orders         FoodTruckOrder[]          @relation("FoodTruckOrders")
  stockItems     FoodTruckStockItem[]      @relation("FoodTruckStockItems")
  checklistItems FoodTruckChecklistItem[]  @relation("FoodTruckChecklistItems")
  finances       FoodTruckFinance[]        @relation("FoodTruckFinances")
  state          FoodTruckState?
}

model FoodTruckMembership {
  id          String            @id @default(cuid())
  role        FoodTruckRole     @default(STAFF)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  workspaceId String
  user        FoodTruckUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   FoodTruckWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

model FoodTruckSession {
  id         String       @id @default(cuid())
  tokenHash  String       @unique
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  revokedAt  DateTime?
  userId     String
  user       FoodTruckUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FoodTruckInvite {
  id          String            @id @default(cuid())
  email       String
  role        FoodTruckRole     @default(STAFF)
  tokenHash   String            @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime          @default(now())
  workspaceId String
  invitedById String
  workspace   FoodTruckWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   FoodTruckUser      @relation("FoodTruckInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model FoodTruckProduct {
  id          String             @id @default(cuid())
  workspaceId String
  name        String
  category    String             @default("Général")
  price       Float
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   FoodTruckWorkspace @relation("FoodTruckProducts", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FoodTruckOrder {
  id          String             @id @default(cuid())
  workspaceId String
  client      String
  status      String             @default("attente")
  orderDate   DateTime           @db.Date
  total       Float
  lines       FoodTruckOrderLine[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   FoodTruckWorkspace @relation("FoodTruckOrders", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([orderDate])
}

model FoodTruckOrderLine {
  id          String        @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  qty         Int
  unitPrice   Float
  order       FoodTruckOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model FoodTruckStockItem {
  id          String             @id @default(cuid())
  workspaceId String
  name        String
  category    String             @default("Général")
  qty         Float
  unit        String             @default("pcs")
  minQty      Float
  dlc         DateTime?          @db.Date
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   FoodTruckWorkspace @relation("FoodTruckStockItems", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FoodTruckChecklistItem {
  id          String             @id @default(cuid())
  workspaceId String
  label       String
  done        Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   FoodTruckWorkspace @relation("FoodTruckChecklistItems", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FoodTruckFinance {
  id           String             @id @default(cuid())
  workspaceId  String
  financeDate  DateTime           @db.Date
  cash         Float              @default(0)
  card         Float              @default(0)
  deliveryApps Float              @default(0)
  expenses     Float              @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  workspace    FoodTruckWorkspace @relation("FoodTruckFinances", fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, financeDate])
  @@index([workspaceId])
}

model FoodTruckState {
  id          String             @id @default(cuid())
  workspaceId String             @unique
  data        Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   FoodTruckWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
